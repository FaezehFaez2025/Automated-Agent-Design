# Copy to `.env`; python-dotenv loads it automatically. Fill in exactly
# one of the two blocks below.

# ── OpenAI (via az.gptplus5.com proxy) ───────────────────────────────
OPENAI_API_KEY="sk-1j4Q37es8fkgbXQHRfivRx8iSoqxuKUDp5AUoczVQosJOGQG"
OPENAI_BASE_URL="https://az.gptplus5.com/v1"

# The agents-SDK exports traces to api.openai.com using OPENAI_API_KEY,
# which 401s on a proxy key. Disable tracing to silence that.
OPENAI_AGENTS_DISABLE_TRACING="1"

# ── Azure OpenAI ─────────────────────────────────────────────────────
# AZURE_OPENAI_API_KEY=""
# AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/openai/v1/"
